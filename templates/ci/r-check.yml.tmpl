name: {{PROJECT_NAME}}

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  r-check:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4

      - uses: r-lib/actions/setup-r@v2
        with:
          r-version: "release"

      - name: Cache renv library
        if: hashFiles('renv.lock') != ''
        uses: actions/cache@v4
        with:
          path: ~/.cache/R/renv
          key: renv-${{ runner.os }}-${{ hashFiles('renv.lock') }}
          restore-keys: renv-${{ runner.os }}-

      - name: Install rv
        run: |
          git clone https://github.com/matthewmazurek/rv.git ~/.rv
          echo "$HOME/.rv" >> $GITHUB_PATH

      - name: Install dependencies
        run: rv sync

      - name: Run analysis
        run: Rscript scripts/run_analysis.R
