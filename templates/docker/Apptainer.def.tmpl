Bootstrap: docker
From: rocker/r-ver:4.4.0

%labels
    Name {{PROJECT_NAME}}

%post
    apt-get update && apt-get install -y --no-install-recommends \
        libcurl4-openssl-dev \
        libssl-dev \
        libxml2-dev \
        libfontconfig1-dev \
        libharfbuzz-dev \
        libfribidi-dev \
        libfreetype6-dev \
        libpng-dev \
        libtiff5-dev \
        libjpeg-dev \
        python3 python3-pip \
    && rm -rf /var/lib/apt/lists/*
    pip3 install --break-system-packages git+https://github.com/matthewmazurek/rv.git

%files
    . /project

%post
    cd /project && rv sync

%runscript
    cd /project && rv run -- "$@"
