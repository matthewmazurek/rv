#!/usr/bin/env bash
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
PROJECT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
exec uv run --project "$PROJECT_DIR" python "$PROJECT_DIR/rv.py" "$@"
